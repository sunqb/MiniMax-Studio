# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_PAYG_API_KEY=your_minimax_payg_api_key   # 可选，按量付费 Key，优先用于声音复刻
MINIMAX_BASE_URL=https://api.minimaxi.com

# Cloudflare R2 配置
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# 服务配置
PORT=8080
GIN_MODE=release
SITE_PASSWORD=change_me_site_password

# 已复刻音色 ID（可选，逗号分隔；适合把本地复刻的音色同步到服务器列表）
# CLONED_VOICE_IDS=my_custom_voice_01,my_custom_voice_02

# 历史记录数据库（默认 data/history.db，Docker 中挂载 ./data 即可持久化）
# DB_PATH=data/history.db
